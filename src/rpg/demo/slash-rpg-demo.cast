[7.929066, "o", "rpg 0.9.0+4-660cafdb (660cafdb, built 2026-03-28)"]
[7.929573, "o", "\r\nServer: PostgreSQL 17.7 (Debian 17.7-3.pgdg13+1)\r\nAI: anthropic configured but $RPG_ANTHROPIC_KEY is not set — /fix /explain /optimize unavailable\r\nType \\? for help. \\-commands are psql-compatible; /-commands are rpg extensions (AI and non-AI).\r\n"]
