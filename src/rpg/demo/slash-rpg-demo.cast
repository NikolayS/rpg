[14.147542, "o", "\r\n"]
[14.147959, "o", "\u001b[38;5;11m⚔  Combat begins: Zombie Connection (HP: 25)\r\n\u001b[0m   Its last_active was 14 days ago. It has forgotten why it came here.\r\n   Commands: attack (a), use <item>, flee (f)\r\n\r\n   You: \u001b[38;5;10m100/100\u001b[0m  |  Zombie Connection: \u001b[38;5;10m25/25\u001b[0m\r\n   > "]
[15.160666, "o", "a"]
[15.289228, "o", "\r\n"]
[15.290892, "o", "\u001b[38;5;14m"]
[15.290997, "o", "   You attack for 16 damage."]
[15.291176, "o", "\r\n\u001b[0m\u001b[38;5;11m   Zombie Connection attacks you for 7 damage.\r\n\u001b[0m\r\n   You: \u001b[38;5;10m93/100\u001b[0m  |  Zombie Connection: \u001b[38;5;11m9/25\u001b[0m\r\n   > "]
[16.097157, "o", "a"]
[16.170081, "o", "\r\n"]
