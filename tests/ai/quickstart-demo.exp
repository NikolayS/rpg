#!/usr/bin/expect -f

# Reliable sleep: busy-wait so asciinema timing is accurate
proc wait {secs} {
    set end [expr {[clock seconds] + $secs}]
    while {[clock seconds] < $end} {
        expect -timeout 1 -re {XXXXWILLNEVERMATCH} {}
    }
}

# Human-like typing: one char at a time, 60-140ms per keystroke
proc human_type {text} {
    foreach char [split $text ""] {
        send -- $char
        after [expr {60 + int(rand() * 80)}]
    }
}

set timeout 120

# Load Anthropic key
set keyfile [open /tmp/rpg-env r]
set keyline [gets $keyfile]
close $keyfile
regexp {RPG_ANTHROPIC_KEY=(.+)} $keyline -> rpg_key

spawn env TERM=xterm-256color COLORTERM=truecolor COLUMNS=120 LINES=35 \
    RPG_ANTHROPIC_KEY=$rpg_key \
    asciinema rec /tmp/rpg-761-pgash/demos/quickstart-demo.cast \
    --overwrite --cols 120 --rows 35

# Wait for shell prompt
expect -re {\$\s}

# cd into repo so ./target/debug/rpg works
send "cd /tmp/rpg-761-pgash\r"
expect -re {\$\s}

# Brief pause before starting
wait 1

# --- Connect to clean demo DB ---
human_type "./target/debug/rpg postgresql://postgres@127.0.0.1:15433/demodb"
send "\r"

# Wait for rpg prompt (demodb=#)
expect -re {demodb[=#>\|]} { wait 1 }

# --- /version ---
human_type "/version"
send "\r"
expect -re {demodb[=#>\|]} { wait 1 }

# --- \d (list tables: customers, orders, products) ---
human_type "\\d"
send "\r"
expect -re {demodb[=#>\|]} { wait 1 }

# --- Intentional typo ---
human_type "select * from orderss limit 1;"
send "\r"
expect -re {demodb[=#>\|]} { wait 1 }

# --- /fix — AI corrects "orderss" -> "orders", we accept and it runs ---
human_type "/fix"
send "\r"
# Wait for AI response + Execute? prompt (may take 2-3s)
expect -re {Execute\?} { wait 2 }
# Accept — run the corrected query
send "y"
expect -re {demodb[=#>\|]} { wait 1 }

# --- /ash (samples pg_stat_activity server-wide, sees pgbench on ashtest) ---
human_type "/ash"
send "\r"
# Let bars accumulate (pgbench running in background on ashtest)
wait 9

# Drill down: arrow down to select top wait type, Enter to expand
send "\033\[B"
wait 1
send "\r"
wait 4

# Exit /ash
send "q"
expect -re {demodb[=#>\|]} { wait 1 }

# Quit rpg
send "\\q\r"
wait 1

# End recording
send "\x04"
wait 1
